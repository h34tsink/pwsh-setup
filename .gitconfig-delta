[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Dracula
    minus-style = "syntax #3a1d2e"
    minus-emph-style = "syntax #6e2740"
    plus-style = "syntax #1d3a2e"
    plus-emph-style = "syntax #276e40"

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
